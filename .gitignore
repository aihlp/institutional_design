```gitignore
# Compiled Python files
*.pyc
__pycache__/

# Logs and temporary files
*.log
*.tmp

# Environment files
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/

# Coverage reports
.coverage
coverage/
htmlcov/

# Python cache
.mypy_cache/
.pytest_cache/

# Build/dist directories
dist/
build/
target/

# Virtual environments
.venv/
venv/
env/

# Node modules (if any)
node_modules/

# OS specific
.DS_Store
Thumbs.db
```