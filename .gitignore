```gitignore
# Compiled Python files
*.pyc
__pycache__/

# Logs
*.log

# Environment files
.env
.env.local
*.env.*

# Dependencies
.venv/
venv/
node_modules/

# Build artifacts
dist/
build/
target/

# Editors
.vscode/
.idea/

# Coverage reports
coverage/
htmlcov/
.coverage

# Testing
.pytest_cache/
.mypy_cache/
```